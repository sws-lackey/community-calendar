{
  "name": "Community Calendar",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/anthropics/claude-code-devcontainer-feature/claude-code:latest": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/supabase/devcontainer-features/supabase-cli:1": {}
  },
  "postCreateCommand": "pip install -r requirements.txt && cd react-app && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "forwardPorts": [8080, 5173]
}
