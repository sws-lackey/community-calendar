BEGIN:VEVENT
SUMMARY:Watercolor Still Life for Teens
DTSTART;TZID=PDT;VALUE=DATE-TIME:20260313T160000
DTEND;TZID=PDT;VALUE=DATE-TIME:20260313T173000
UID:3bffdbdd6f32cf80960678b3317f16e2@multcolib.org
