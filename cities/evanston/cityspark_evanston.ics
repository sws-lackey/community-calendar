BEGIN:VEVENT
SUMMARY:The Factory Theater's "The Sporting Life"
DTSTART;TZID=CDT;VALUE=DATE-TIME:20260501T200000
DTEND;TZID=CDT;VALUE=DATE-TIME:20260501T223000
UID:260209tH_1Z6zIWkOrpiyUgAkC-w
